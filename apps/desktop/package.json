{
  "name": "@tiles-engine/desktop",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "node ./node_modules/@tauri-apps/cli/tauri.js dev",
    "tauri:build": "node ./node_modules/@tauri-apps/cli/tauri.js build",
    "check": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.4.5",
    "vite": "^5.4.8"
  }
}

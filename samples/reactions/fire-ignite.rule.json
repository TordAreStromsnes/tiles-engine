      "tag": "wet"
    },
    {
      "namespace": "state",
      "tag": "burning"
    }
  ],
  "addStateTags": [
    {
      "namespace": "state",
      "tag": "burning"
    }
  ],
  "removeStateTags": [],
  "assetVariantSwitch": null,
  "timing": {
    "delaySeconds": 0.0,
    "durationSeconds": 5.0,
    "tickIntervalSeconds": null
  },

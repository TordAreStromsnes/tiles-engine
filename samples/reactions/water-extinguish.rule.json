{
  "schemaVersion": 0,
  "id": "rule.water.extinguish-fire",
  "name": "Water Extinguishes Burning Target",
  "description": "Water sources remove burning state, add wet/smoking state, then trigger smoke.",
  "sourceTags": [
    {
      "namespace": "source",
      "tag": "water"
    }
  ],
  "requiredTargetTags": [
    {
      "namespace": "state",
      "tag": "burning"
    }
  ],
  "blockedTargetTags": [],
  "addStateTags": [
    {
      "namespace": "state",
      "tag": "wet"
    },
    {
      "namespace": "state",
      "tag": "smoking"
    }
  ],
  "removeStateTags": [
    {
      "namespace": "state",
      "tag": "burning"
    }
  ],
  "assetVariantSwitch": {
    "stateVariantId": "wet",
    "when": "onStart"
  },
  "timing": {
    "delaySeconds": 0.0,
    "durationSeconds": 1.0,
    "tickIntervalSeconds": null
  },
  "triggeredEffects": [
    {
      "effectId": "effect.smoke.puff",
      "when": "onStart"
    }
  ],
  "tags": ["water", "state-change"]
}

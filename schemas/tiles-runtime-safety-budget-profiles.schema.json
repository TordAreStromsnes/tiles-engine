{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-runtime-safety-budget-profiles.schema.json",
  "title": "Tiles Engine Runtime Safety Budget Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profiles"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "id", "name", "kind", "limits"],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "const": 0
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["tiny", "standard", "large", "experimental"]
        },
        "limits": {
          "$ref": "#/$defs/limits"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxTextureDimensionPx",
        "maxAtlasDimensionPx",
        "maxMapCells",
        "maxEntitiesPerMap",
        "maxActiveParticles",
        "maxMemoryEstimateMb",
        "maxLightEmitters",
        "maxRuleEvaluationsPerTick"
      ],
      "properties": {
        "maxTextureDimensionPx": {
          "type": "integer",
          "description": "Maximum decoded width or height for a source PNG sprite texture.",
          "minimum": 1
        },
        "maxAtlasDimensionPx": {
          "type": "integer",
          "description": "Maximum decoded width or height for a packed texture atlas.",
          "minimum": 1
        },
        "maxMapCells": {
          "type": "integer",
          "minimum": 1
        },
        "maxEntitiesPerMap": {
          "type": "integer",
          "minimum": 1
        },
        "maxActiveParticles": {
          "type": "integer",
          "minimum": 1
        },
        "maxMemoryEstimateMb": {
          "type": "integer",
          "minimum": 1
        },
        "maxLightEmitters": {
          "type": "integer",
          "minimum": 1
        },
        "maxRuleEvaluationsPerTick": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

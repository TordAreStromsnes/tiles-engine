{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-scene.schema.json",
  "title": "Tiles Engine Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "mapIds",
    "tags",
    "entities"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mapIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tags": {
      "$ref": "#/$defs/tags"
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entity"
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "assetId",
        "mapId",
        "position",
        "facing",
        "tags",
        "components"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "assetId": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "mapId": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/position"
        },
        "facing": {
          "$ref": "#/$defs/facing"
        },
        "tags": {
          "$ref": "#/$defs/tags"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        }
      }
    },
    "component": {
      "oneOf": [
        {
          "$ref": "#/$defs/playerSpawnComponent"
        },
        {
          "$ref": "#/$defs/playerControllerComponent"
        },
        {
          "$ref": "#/$defs/npcBehaviorComponent"
        },
        {
          "$ref": "#/$defs/interactionTriggerComponent"
        },
        {
          "$ref": "#/$defs/portalLinkComponent"
        }
      ]
    },
    "playerSpawnComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "playerSpawn"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spawnId"],
          "properties": {
            "spawnId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "playerControllerComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "playerController"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "movement",
            "speedUnitsPerSecond",
            "interactionRadius"
          ],
          "properties": {
            "movement": {
              "type": "string",
              "enum": ["gridFourWay", "freeTwoAxis"]
            },
            "speedUnitsPerSecond": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "interactionRadius": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "npcBehaviorComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "npcBehavior"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["behavior", "homePosition", "wanderRadius"],
          "properties": {
            "behavior": {
              "type": "string",
              "enum": ["idle", "boundedWander"]
            },
            "homePosition": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "$ref": "#/$defs/position"
                }
              ]
            },
            "wanderRadius": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              ]
            }
          }
        }
      }
    },
    "interactionTriggerComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "interactionTrigger"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "triggerId",
            "promptId",
            "eventId",
            "targetEntityId",
            "radius",
            "repeatable"
          ],
          "properties": {
            "triggerId": {
              "type": "string",
              "minLength": 1
            },
            "promptId": {
              "$ref": "#/$defs/optionalString"
            },
            "eventId": {
              "$ref": "#/$defs/optionalString"
            },
            "targetEntityId": {
              "$ref": "#/$defs/optionalString"
            },
            "radius": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "repeatable": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "portalLinkComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "portalLink"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "portalId",
            "targetMapId",
            "targetPortalId",
            "spawn",
            "facing"
          ],
          "properties": {
            "portalId": {
              "type": "string",
              "minLength": 1
            },
            "targetMapId": {
              "type": "string",
              "minLength": 1
            },
            "targetPortalId": {
              "$ref": "#/$defs/optionalString"
            },
            "spawn": {
              "$ref": "#/$defs/gridPoint"
            },
            "facing": {
              "$ref": "#/$defs/facing"
            }
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "gridPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["column", "row"],
      "properties": {
        "column": {
          "type": "integer",
          "minimum": 0
        },
        "row": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "facing": {
      "type": "string",
      "enum": ["north", "south", "east", "west"]
    },
    "optionalString": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

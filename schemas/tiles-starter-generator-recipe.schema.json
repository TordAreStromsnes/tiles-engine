{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-starter-generator-recipe.schema.json",
  "title": "Tiles Engine Starter Generator Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "generatorId",
    "generatorVersion",
    "seed",
    "target",
    "tileSize",
    "style",
    "palette",
    "parameters",
    "bakedAssetIds",
    "provenance"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "generatorId": {
      "$ref": "#/$defs/id"
    },
    "generatorVersion": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "tileSize": {
      "$ref": "#/$defs/tileSize"
    },
    "style": {
      "$ref": "#/$defs/style"
    },
    "palette": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/paletteSlot"
      },
      "uniqueItems": true
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/parameter"
      },
      "uniqueItems": true
    },
    "bakedAssetIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "outputKind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["terrainTileSet", "placeholderCharacter", "propSprite"]
        },
        "outputKind": {
          "type": "string",
          "enum": ["sprite", "spriteSource", "tileSet", "assetPack"]
        }
      }
    },
    "tileSize": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": ["styleId", "materialType", "tags"],
      "properties": {
        "styleId": {
          "$ref": "#/$defs/id"
        },
        "materialType": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "$ref": "#/$defs/tags"
        }
      }
    },
    "paletteSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slotId", "swatches"],
      "properties": {
        "slotId": {
          "$ref": "#/$defs/id"
        },
        "swatches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^#?[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
          }
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value"],
      "properties": {
        "key": {
          "$ref": "#/$defs/id"
        },
        "value": {
          "not": {
            "type": "null"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic", "createdWithTilesVersion", "notes"],
      "properties": {
        "deterministic": {
          "type": "boolean",
          "const": true
        },
        "createdWithTilesVersion": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-animation-clip.schema.json",
  "title": "Tiles Engine Animation Clip",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "target",
    "source",
    "frameRate",
    "loopMode",
    "tags",
    "viewTracks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "frameRate": {
      "type": "integer",
      "minimum": 1
    },
    "loopMode": {
      "type": "string",
      "enum": ["once", "loop", "pingPong"]
    },
    "tags": {
      "$ref": "#/$defs/tags"
    },
    "viewTracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/viewTrack"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId", "bodyPlanId"],
      "properties": {
        "assetId": {
          "type": "string",
          "minLength": 1
        },
        "bodyPlanId": {
          "type": "string",
          "minLength": 1
        },
        "rigId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "readOnly"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": [
            "builtInTemplate",
            "projectLocalCopy",
            "custom",
            "importedFrameSheet"
          ]
        },
        "readOnly": {
          "type": "boolean"
        },
        "templateId": {
          "type": "string",
          "minLength": 1
        },
        "copiedFromTemplateId": {
          "type": "string",
          "minLength": 1
        },
        "copiedFromTemplateVersion": {
          "type": "string",
          "minLength": 1
        },
        "sourceAssetId": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "viewTrack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "frames"],
      "properties": {
        "view": {
          "$ref": "#/$defs/view"
        },
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/frame"
          }
        }
      }
    },
    "view": {
      "type": "string",
      "enum": ["front", "back", "left", "right", "topDown"]
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["durationTicks", "layerPoses", "attachmentPoses", "eventIds"],
      "properties": {
        "durationTicks": {
          "type": "integer",
          "minimum": 1
        },
        "bodyPartPoses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bodyPartPose"
          }
        },
        "layerPoses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/layerPose"
          }
        },
        "attachmentPoses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachmentPose"
          }
        },
        "attachmentEvents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachmentEvent"
          }
        },
        "paletteEvents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/paletteEvent"
          }
        },
        "eventIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "bodyPartPose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "partId",
        "translation",
        "rotationDegrees",
        "scale",
        "opacity"
      ],
      "properties": {
        "partId": {
          "type": "string",
          "minLength": 1
        },
        "translation": {
          "$ref": "#/$defs/point2"
        },
        "rotationDegrees": {
          "type": "number"
        },
        "scale": {
          "$ref": "#/$defs/positivePoint2"
        },
        "opacity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "layerPose": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layerId",
        "translation",
        "rotationDegrees",
        "scale",
        "opacity"
      ],
      "properties": {
        "layerId": {
          "type": "string",
          "minLength": 1
        },
        "translation": {
          "$ref": "#/$defs/point2"
        },
        "rotationDegrees": {
          "type": "number"
        },
        "scale": {
          "$ref": "#/$defs/positivePoint2"
        },
        "opacity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "attachmentPose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachmentPointId", "translation", "rotationDegrees"],
      "properties": {
        "attachmentPointId": {
          "type": "string",
          "minLength": 1
        },
        "translation": {
          "$ref": "#/$defs/point2"
        },
        "rotationDegrees": {
          "type": "number"
        }
      }
    },
    "attachmentEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "attachmentId", "action"],
      "properties": {
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "attachmentId": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["attach", "detach", "show", "hide", "trigger"]
        }
      }
    },
    "paletteEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slotId", "swatch", "transitionTicks"],
      "properties": {
        "slotId": {
          "type": "string",
          "minLength": 1
        },
        "swatch": {
          "type": "string",
          "minLength": 1
        },
        "transitionTicks": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "point2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "positivePoint2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "y": {
          "type": "number",
          "exclusiveMinimum": 0.0
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

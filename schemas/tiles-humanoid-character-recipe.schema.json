{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-humanoid-character-recipe.schema.json",
  "title": "Tiles Engine Humanoid Character Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "bodyPlan",
    "tags",
    "proportions",
    "directions",
    "palettes",
    "parts",
    "warnings",
    "bakedOutputs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "bodyPlan": {
      "$ref": "#/$defs/bodyPlan"
    },
    "tags": {
      "$ref": "#/$defs/tags"
    },
    "proportions": {
      "$ref": "#/$defs/proportions"
    },
    "directions": {
      "$ref": "#/$defs/directions"
    },
    "palettes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/paletteSelection"
      },
      "uniqueItems": true
    },
    "parts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/part"
      },
      "uniqueItems": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "bakedOutputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bakedOutput"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "bodyPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "requiredPartSlots",
        "optionalPartSlots",
        "plannedDirections"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["humanoid"]
        },
        "requiredPartSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/partSlot"
          },
          "uniqueItems": true
        },
        "optionalPartSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/partSlot"
          },
          "uniqueItems": true
        },
        "plannedDirections": {
          "$ref": "#/$defs/directions"
        }
      }
    },
    "proportions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bodyHeight",
        "bodyWidth",
        "headSize",
        "shoulderWidth",
        "armLength",
        "legLength",
        "footSize"
      ],
      "properties": {
        "bodyHeight": {
          "$ref": "#/$defs/proportion"
        },
        "bodyWidth": {
          "$ref": "#/$defs/proportion"
        },
        "headSize": {
          "$ref": "#/$defs/proportion"
        },
        "shoulderWidth": {
          "$ref": "#/$defs/proportion"
        },
        "armLength": {
          "$ref": "#/$defs/proportion"
        },
        "legLength": {
          "$ref": "#/$defs/proportion"
        },
        "footSize": {
          "$ref": "#/$defs/proportion"
        }
      }
    },
    "proportion": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 3.0
    },
    "directions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/direction"
      },
      "uniqueItems": true
    },
    "direction": {
      "type": "string",
      "enum": ["front", "back", "left", "right", "topDown"]
    },
    "paletteSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "swatches"],
      "properties": {
        "slot": {
          "$ref": "#/$defs/paletteSlot"
        },
        "swatches": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
          },
          "uniqueItems": true
        }
      }
    },
    "paletteSlot": {
      "type": "string",
      "enum": [
        "skin",
        "hair",
        "eye",
        "clothingPrimary",
        "clothingSecondary",
        "accessory",
        "outline"
      ]
    },
    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot",
        "assetId",
        "partId",
        "variantId",
        "paletteSlots",
        "directions",
        "attachmentPoints"
      ],
      "properties": {
        "slot": {
          "$ref": "#/$defs/partSlot"
        },
        "assetId": {
          "type": "string",
          "minLength": 1
        },
        "partId": {
          "type": "string",
          "minLength": 1
        },
        "variantId": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "paletteSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/paletteSlot"
          },
          "uniqueItems": true
        },
        "directions": {
          "$ref": "#/$defs/directions"
        },
        "attachmentPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachmentPoint"
          },
          "uniqueItems": true
        }
      }
    },
    "attachmentPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetSlot", "directions"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "targetSlot": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/partSlot"
            }
          ]
        },
        "directions": {
          "$ref": "#/$defs/directions"
        }
      }
    },
    "partSlot": {
      "type": "string",
      "enum": [
        "bodyBase",
        "head",
        "hair",
        "eyes",
        "clothingTop",
        "clothingBottom",
        "shoesFeet",
        "accessory",
        "equipment"
      ]
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "partSlot"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "partSlot": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/partSlot"
            }
          ]
        }
      }
    },
    "bakedOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId", "path", "directions"],
      "properties": {
        "assetId": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "directions": {
          "$ref": "#/$defs/directions"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

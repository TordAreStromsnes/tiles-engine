{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-palette-slot-system.schema.json",
  "title": "Tiles Engine Palette Slot System",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "slots", "themes", "attachmentOverrides"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slot"
      },
      "uniqueItems": true
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/theme"
      },
      "uniqueItems": true
    },
    "attachmentOverrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachmentOverride"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "owner", "required", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "$ref": "#/$defs/owner"
        },
        "required": {
          "type": "boolean"
        },
        "tags": {
          "$ref": "#/$defs/tags"
        }
      }
    },
    "owner": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "character"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "slot"],
          "properties": {
            "kind": {
              "const": "part"
            },
            "slot": {
              "$ref": "#/$defs/partSlot"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "attachmentId"],
          "properties": {
            "kind": {
              "const": "attachment"
            },
            "attachmentId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "bindings"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binding"
          },
          "uniqueItems": true
        }
      }
    },
    "attachmentOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachmentId", "bindings"],
      "properties": {
        "attachmentId": {
          "type": "string",
          "minLength": 1
        },
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binding"
          },
          "uniqueItems": true
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slotId", "swatch"],
      "properties": {
        "slotId": {
          "type": "string",
          "minLength": 1
        },
        "swatch": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        }
      }
    },
    "partSlot": {
      "type": "string",
      "enum": [
        "bodyBase",
        "head",
        "hair",
        "eyes",
        "clothingTop",
        "clothingBottom",
        "shoesFeet",
        "accessory",
        "equipment"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

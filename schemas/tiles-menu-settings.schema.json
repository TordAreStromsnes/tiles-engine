{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-menu-settings.schema.json",
  "title": "Tiles Menu And Settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "menus", "actions", "settings", "tags"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "menus": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/menu"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/settingsGroup"
      }
    },
    "tags": {
      "$ref": "#/$defs/tags"
    }
  },
  "$defs": {
    "menu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "kind", "items"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["title", "pause", "settings", "custom"]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/menuItem"
          }
        }
      }
    },
    "menuItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "enabled", "visible"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/menuItemKind"
        },
        "enabled": {
          "type": "boolean"
        },
        "visible": {
          "type": "boolean"
        }
      }
    },
    "menuItemKind": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "action"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["actionId"],
              "properties": {
                "actionId": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "openMenu"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["menuId"],
              "properties": {
                "menuId": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "setting"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["settingId"],
              "properties": {
                "settingId": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "back"
            }
          }
        }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "command", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "$ref": "#/$defs/actionCommand"
        },
        "tags": {
          "$ref": "#/$defs/tags"
        }
      }
    },
    "actionCommand": {
      "oneOf": [
        {
          "$ref": "#/$defs/unitActionCommand"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "custom"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["commandId"],
              "properties": {
                "commandId": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      ]
    },
    "unitActionCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "startGame",
            "resumeGame",
            "saveGame",
            "loadGame",
            "quitToEditor",
            "quitGame"
          ]
        }
      }
    },
    "settingsGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "settings"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "settings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/setting"
          }
        }
      }
    },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "description", "control", "defaultValue", "tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "control": {
          "$ref": "#/$defs/settingControl"
        },
        "defaultValue": {
          "$ref": "#/$defs/settingValue"
        },
        "tags": {
          "$ref": "#/$defs/tags"
        }
      }
    },
    "settingControl": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "toggle"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "slider"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["min", "max", "step"],
              "properties": {
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "step": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "select"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["options"],
              "properties": {
                "options": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/settingOption"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "settingOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "settingValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "boolean"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": {
                "value": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "number"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": {
                "value": {
                  "type": "number"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "data"],
          "properties": {
            "kind": {
              "const": "text"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["value"],
              "properties": {
                "value": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}

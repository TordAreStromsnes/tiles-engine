{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiles-engine.dev/schemas/tiles-particle-emitter-preset.schema.json",
  "title": "Tiles Engine Particle Emitter Preset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "description",
    "spawn",
    "lifetimeSeconds",
    "velocity",
    "colorOverLifetime",
    "sizeOverLifetime",
    "acceleration",
    "blendMode",
    "emissionMode",
    "attachment",
    "tags"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 0
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "spawn": {
      "$ref": "#/$defs/spawn"
    },
    "lifetimeSeconds": {
      "$ref": "#/$defs/positiveRange"
    },
    "velocity": {
      "$ref": "#/$defs/velocity"
    },
    "colorOverLifetime": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/colorKeyframe"
      },
      "minItems": 1
    },
    "sizeOverLifetime": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sizeKeyframe"
      },
      "minItems": 1
    },
    "acceleration": {
      "$ref": "#/$defs/acceleration"
    },
    "blendMode": {
      "enum": ["alpha", "additive", "multiply"]
    },
    "emissionMode": {
      "$ref": "#/$defs/emissionMode"
    },
    "attachment": {
      "$ref": "#/$defs/attachment"
    },
    "tags": {
      "$ref": "#/$defs/tags"
    }
  },
  "$defs": {
    "spawn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratePerSecond", "maxParticles"],
      "properties": {
        "ratePerSecond": {
          "type": "number",
          "minimum": 0
        },
        "maxParticles": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "positiveRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    },
    "velocity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": {
          "$ref": "#/$defs/range"
        },
        "y": {
          "$ref": "#/$defs/range"
        },
        "z": {
          "$ref": "#/$defs/range"
        }
      }
    },
    "colorKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time", "color"],
      "properties": {
        "time": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "color": {
          "$ref": "#/$defs/color"
        }
      }
    },
    "color": {
      "type": "object",
      "additionalProperties": false,
      "required": ["red", "green", "blue", "alpha"],
      "properties": {
        "red": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "green": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blue": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "sizeKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time", "size"],
      "properties": {
        "time": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "size": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "acceleration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gravity", "drift"],
      "properties": {
        "gravity": {
          "$ref": "#/$defs/vector"
        },
        "drift": {
          "$ref": "#/$defs/vector"
        }
      }
    },
    "vector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "emissionMode": {
      "oneOf": [
        {
          "$ref": "#/$defs/loopingEmission"
        },
        {
          "$ref": "#/$defs/burstEmission"
        }
      ]
    },
    "loopingEmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "looping"
        }
      }
    },
    "burstEmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "burst"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count"],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "attachment": {
      "oneOf": [
        {
          "$ref": "#/$defs/worldAttachment"
        },
        {
          "$ref": "#/$defs/entityAttachment"
        },
        {
          "$ref": "#/$defs/attachmentPointAttachment"
        },
        {
          "$ref": "#/$defs/mapPositionAttachment"
        }
      ]
    },
    "worldAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "world"
        }
      }
    },
    "entityAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "entity"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entityId"],
          "properties": {
            "entityId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "attachmentPointAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "attachmentPoint"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entityId", "attachmentPointId"],
          "properties": {
            "entityId": {
              "type": "string",
              "minLength": 1
            },
            "attachmentPointId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "mapPositionAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "data"],
      "properties": {
        "kind": {
          "const": "mapPosition"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mapId", "position"],
          "properties": {
            "mapId": {
              "type": "string",
              "minLength": 1
            },
            "position": {
              "$ref": "#/$defs/position"
            }
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
